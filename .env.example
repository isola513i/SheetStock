# Google Sheets server-side integration (preferred: service account)
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@project-id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID="your-spreadsheet-id"
GOOGLE_SHEETS_RANGE="inventory!A:K"

# Auth token signing secret (generate with: openssl rand -base64 32)
TOKEN_SECRET="your-random-secret-here"

# Optional fallback for public sheets:
GOOGLE_API_KEY="your-google-api-key"
